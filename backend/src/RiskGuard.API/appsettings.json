{
  "AllowedHosts": "*",
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "RiskGuard": "Data Source=riskguard.db"
  },
  "Jwt": {
    "Issuer": "RiskGuardAI",
    "Audience": "RiskGuardAI.Web",
    "Secret": "JWT_SECRET",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Authentication": {
    "AllowPublicRegistration": false,
    "RequireConfirmedEmail": false
  },
  "SeedData": {
    "Enabled": false
  },
  "Swagger": {
    "Enabled": false
  },
  "AzureOpenAI": {
    "Endpoint": "AZURE_OPENAI_ENDPOINT",
    "Key": "AZURE_OPENAI_KEY",
    "Deployment": "AZURE_OPENAI_DEPLOYMENT"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
