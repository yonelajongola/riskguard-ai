{
  "Database": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "RiskGuard": "SQL_CONNECTION_STRING"
  },
  "Jwt": {
    "Secret": "JWT_SECRET"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://YOUR-FRONTEND-NAME.azurestaticapps.net"
    ]
  },
  "Authentication": {
    "AllowPublicRegistration": false
  },
  "SeedData": {
    "Enabled": false
  },
  "Swagger": {
    "Enabled": false
  }
}
